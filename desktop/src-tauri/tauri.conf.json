{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pesacast",
  "identifier": "com.pesacast.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "pesacast",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "REPLACE_WITH_OUTPUT_OF_cargo_tauri_signer_generate",
      "endpoints": [
        "https://github.com/davidamunga/pesacast/releases/latest/download/latest.json"
      ]
    }
  }
}
