{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "notification:default",
    "blec:default",
    "updater:default",
    "process:default",
    "dialog:default",
    "http:default",
    "http:allow-fetch",
    {
      "identifier": "http:allow-fetch",
      "allow": [
        { "url": "http://**/**" },
        { "url": "https://**/**" },
        { "url": "http://localhost" },
        { "url": "http://localhost/**" },
        { "url": "http://localhost:*" },
        { "url": "http://localhost:*/**" }
      ]
    }
  ]
}
